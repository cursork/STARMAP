 NAMES‚Üê11‚ÜëPLANETNAMES
 :For I :In ‚ç≥11
   Z,‚Üê'<text class="planet" id="p',(‚çïI-1),'" x="0" y="0" visibility="hidden">',PCHARS[I],'</text>'
