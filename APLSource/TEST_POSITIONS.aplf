 Rв†ђTEST_POSITIONS;REF;STAR_REF;MOON_REF;SUN_REF;COMPUTED_STARS;COMPUTED_MOON;COMPUTED_SUN;RA_DEG;RA_ERR;DEC_ERR;TOTAL_ERR;MAX_ERR;WORST;NFAIL;STAR_TOL;MOON_TOL;SUN_TOL;MOON_ERR;SUN_ERR
вЌќ Test computed positions against Skyfield/JPL Horizons reference
вЌќ Observation: 1974-05-16 05:00 UTC, Anaheim CA (33.767N, 117.833W)
вЌќ reference_positions: 334x2 matrix (332 stars + Moon + Sun)
вЌќ Rows 1-332: apparent RA/Dec from Skyfield (J2000 precessed)
вЌќ Row 333: Moon geocentric apparent from JPL DE421
вЌќ Row 334: Sun geocentric apparent from JPL DE421
 Rв†ђ1

вЌќ Tolerances (degrees of angular separation)
 STAR_TOLв†ђ0.15  вЌќ Linear precession vs IAU + no nutation/aberration
 MOON_TOLв†ђ10    вЌќ Keplerian model vs full perturbation theory
 SUN_TOLв†ђ3      вЌќ Keplerian Earth orbit (inherent ~2.6deg LST error)

вЌќ Set observation parameters (Anaheim test case)
 STATEDDAYNOв†ђJNU 5 16 1974
 STATEDTIMEв†ђ5
 LONGв†ђВЇ117.833
 LATв†ђ33.767
 TIMEв†ђLONG TIMEADJUST STATEDTIME
 DATEв†ђSTATEDDAYNO+(TIMEГ·24)-LONGГ·360

вЌќ Load reference
 REFв†ђreference_positions
 STAR_REFв†ђREF[вЌі332;]
 MOON_REFв†ђREF[333;]
 SUN_REFв†ђREF[334;]

вЌќ === Stars: test precession ===
 COMPUTED_STARSв†ђ(DATE-CATEPOCH)PRECESS STARS
вЌќ RA difference in degrees, with wraparound
 RA_DEGв†ђ15Г—|COMPUTED_STARS[;1]-STAR_REF[;1]
 RA_DEGв†ђRA_DEGвЊЉ360-RA_DEG
вЌќ Weight RA by cos(Dec) for correct angular distance near poles
 RA_ERRв†ђ(COS RADIAN STAR_REF[;2])Г—RA_DEG
 DEC_ERRв†ђ|COMPUTED_STARS[;2]-STAR_REF[;2]
 TOTAL_ERRв†ђ(((RA_ERR*2))+DEC_ERR*2)*0.5
 MAX_ERRв†ђвЊ€/TOTAL_ERR
 NFAILв†ђ+/TOTAL_ERR>STAR_TOL

 :If MAX_ERR>STAR_TOL
   WORSTв†ђTOTAL_ERRвЌівЊ€/TOTAL_ERR
   вЋ•в†ђ'FAIL: Stars max error ',(вЌ•MAX_ERR),'deg at star ',(вЌ•WORST),' (tolerance ',(вЌ•STAR_TOL),'deg, ',(вЌ•NFAIL),' failed)'
   Rв†ђ0
 :EndIf

вЌќ === Moon: test MOONPOS ===
 COMPUTED_MOONв†ђMOONPOS DATE
вЌќ MOONPOS returns 1x3 matrix (RA hours, Dec degrees, distance)
 RA_DEGв†ђ15Г—|COMPUTED_MOON[1;1]-MOON_REF[1]
 RA_DEGв†ђRA_DEGвЊЉ360-RA_DEG
 RA_ERRв†ђ(COS RADIAN MOON_REF[2])Г—RA_DEG
 DEC_ERRв†ђ|COMPUTED_MOON[1;2]-MOON_REF[2]
 MOON_ERRв†ђ(((RA_ERR*2))+DEC_ERR*2)*0.5

 :If MOON_ERR>MOON_TOL
   вЋ•в†ђ'FAIL: Moon error ',(вЌ•MOON_ERR),'deg (tolerance ',(вЌ•MOON_TOL),'deg)'
   вЋ•в†ђ'  computed RA ',(вЌ•COMPUTED_MOON[1;1]),'h Dec ',(вЌ•COMPUTED_MOON[1;2]),'deg'
   вЋ•в†ђ'  reference RA ',(вЌ•MOON_REF[1]),'h Dec ',(вЌ•MOON_REF[2]),'deg'
   Rв†ђ0
 :EndIf

вЌќ === Sun: test EARTHVIEW ===
 COMPUTED_SUNв†ђDATE EARTHVIEW 1 3вЌґ0 0 0
вЌќ EARTHVIEW returns 1x3 matrix (RA hours, Dec degrees, distance)
 RA_DEGв†ђ15Г—|COMPUTED_SUN[1;1]-SUN_REF[1]
 RA_DEGв†ђRA_DEGвЊЉ360-RA_DEG
 RA_ERRв†ђ(COS RADIAN SUN_REF[2])Г—RA_DEG
 DEC_ERRв†ђ|COMPUTED_SUN[1;2]-SUN_REF[2]
 SUN_ERRв†ђ(((RA_ERR*2))+DEC_ERR*2)*0.5

 :If SUN_ERR>SUN_TOL
   вЋ•в†ђ'FAIL: Sun error ',(вЌ•SUN_ERR),'deg (tolerance ',(вЌ•SUN_TOL),'deg)'
   вЋ•в†ђ'  computed RA ',(вЌ•COMPUTED_SUN[1;1]),'h Dec ',(вЌ•COMPUTED_SUN[1;2]),'deg'
   вЋ•в†ђ'  reference RA ',(вЌ•SUN_REF[1]),'h Dec ',(вЌ•SUN_REF[2]),'deg'
   Rв†ђ0
 :EndIf

 :If R
   вЋ•в†ђ'PASS: TEST_POSITIONS (332 stars max ',(вЌ•MAX_ERR),'deg, Moon ',(вЌ•MOON_ERR),'deg, Sun ',(вЌ•SUN_ERR),'deg)'
 :EndIf
