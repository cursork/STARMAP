:Class WebApp
‚ćĚ HTTP server for star map animation
‚ćĚ Built on Stark ‚ÄĒ serves web UI, generates animations, serves video files
‚ćĚ
‚ćĚ   app‚Üź‚éēNEW sm.WebApp (Stark.Stark #.sm)
‚ćĚ   app.Start 8080

    :Field Private router
    :Field Private root
    :Field Private ns

    ‚ąá Make args;StarkClass
      :Access Public
      :Implements Constructor
      (StarkClass ns)‚Üźargs
      root‚Üź(‚ąä‚äÉ‚éēSHELL 'pwd')~‚éēUCS 10 13
      {}‚éēSHELL 'mkdir -p ',root,'/output'
      router‚Üź‚éēNEW StarkClass
      router.Handlers‚Üź‚éēTHIS
      router.ThreadMode‚Üź'DEBUG'
      '/' router.Get 'ServeUI'
      '/api/generate' router.Post 'Generate'
      '/api/video/{id}/animation.mp4' router.Get 'ServeVideo'
    ‚ąá

    ‚ąá Start port
      :Access Public
      router.Start port
      ‚éē‚Üź'Star map server running on http://localhost:',(‚ćēport)
    ‚ąá

    ‚ąá Stop
      :Access Public
      router.Stop
      ‚éē‚Üź'Server stopped'
    ‚ąá

    ‚ąá result‚ÜźServeUI req
      :Access Public
      'Content-Type' req.SetHeader 'text/html; charset=utf-8'
      req.Response.Payload‚Üź‚äÉ‚éēNGET(root,'/web/index.html')
      result‚Üź‚ć¨
    ‚ąá

    ‚ąá result‚ÜźGenerate req;body;START;END;T;LA;LO;FPS;ID;DIR;VID
      :Access Public
      :Trap 0
          body‚Üźreq.Payload
          START‚Üźbody.start
          END‚Üźbody.end
          T‚Üźbody.time
          LA‚Üźbody.lat
          LO‚Üźbody.long
          FPS‚Üźbody.fps
          ID‚Üź(‚ąä‚äÉ‚éēSHELL 'date +%Y%m%d%H%M%S')~‚éēUCS 10 13 32
          DIR‚Üźroot,'/output/',ID
          {}‚éēSHELL 'mkdir -p ',DIR
          ‚éē‚Üź'Generating frames for ',ID,'...'
          START END T LA LO ns.ANIMATE DIR
          ‚éē‚Üź'Converting to video...'
          VID‚ÜźFPS ns.MAKEVIDEO DIR
          :If 0<‚ČĘVID
              result‚Üź(url: '/api/video/',ID,'/animation.mp4')
          :Else
              req.Fail 500
              result‚Üź(error: 'Video generation failed')
          :EndIf
      :Else
          req.Fail 400
          result‚Üź(error: ‚éēDMX.Message)
      :EndTrap
    ‚ąá

    ‚ąá result‚ÜźServeVideo req;id;path
      :Access Public
      id‚Üźreq.PathParams.id
      :If ‚ą®/'..'‚ć∑id
          req.Fail 403
          result‚Üź(error: 'Forbidden')
          :Return
      :EndIf
      path‚Üźroot,'/output/',id,'/animation.mp4'
      :If ‚éēNEXISTS path
          'Content-Type' req.SetHeader 'video/mp4'
          req.Response.Payload‚Üź'' path
          result‚Üź‚ć¨
      :Else
          req.Fail 404
          result‚Üź(detail: 'Video not found')
      :EndIf
    ‚ąá

:EndClass
