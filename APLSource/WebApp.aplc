:Class WebApp
‚çù HTTP server for star map animation
‚çù Built on Stark ‚Äî serves web UI, generates animations, serves video files
‚çù
‚çù   app‚Üê‚éïNEW sm.WebApp (Stark.Stark #.sm)
‚çù   app.Start 8080

    :Field Private router
    :Field Private root
    :Field Private ns

    ‚àá Make args;StarkClass
      :Access Public
      :Implements Constructor
      (StarkClass ns)‚Üêargs
      root‚Üê(‚àä‚äÉ‚éïSHELL 'pwd')~‚éïUCS 10 13
      {}‚éïSHELL 'mkdir -p ',root,'/output'
      router‚Üê‚éïNEW StarkClass
      router.Handlers‚Üê‚éïTHIS
      router.ThreadMode‚Üê'DEBUG'
      '/' router.Get 'ServeUI'
      '/api/generate' router.Post 'Generate'
      '/api/generate-svg' router.Post 'GenerateSVG'
      '/api/video/{id}/animation.mp4' router.Get 'ServeVideo'
      '/api/svg/{id}' router.Get 'ServeSVG'
    ‚àá

    ‚àá Start port
      :Access Public
      router.Start port
      ‚éï‚Üê'Star map server running on http://localhost:',(‚çïport)
    ‚àá

    ‚àá Stop
      :Access Public
      router.Stop
      ‚éï‚Üê'Server stopped'
    ‚àá

    ‚àá result‚ÜêServeUI req
      :Access Public
      'Content-Type' req.SetHeader 'text/html; charset=utf-8'
      req.Response.Payload‚Üê‚äÉ‚éïNGET(root,'/web/index.html')
      result‚Üê‚ç¨
    ‚àá

    ‚àá result‚ÜêGenerate req;body;START;END;T;LA;LO;FPS;ID;DIR;VID
      :Access Public
      :Trap 0
          body‚Üêreq.Payload
          START‚Üêbody.start
          END‚Üêbody.end
          T‚Üêbody.time
          LA‚Üêbody.lat
          LO‚Üêbody.long
          FPS‚Üêbody.fps
          ID‚Üê(‚àä‚äÉ‚éïSHELL 'date +%Y%m%d%H%M%S')~‚éïUCS 10 13 32
          DIR‚Üêroot,'/output/',ID
          {}‚éïSHELL 'mkdir -p ',DIR
          ‚éï‚Üê'Generating frames for ',ID,'...'
          START END T LA LO ns.ANIMATE DIR
          ‚éï‚Üê'Converting to video...'
          VID‚ÜêFPS ns.MAKEVIDEO DIR
          :If 0<‚â¢VID
              result‚Üê(url: '/api/video/',ID,'/animation.mp4')
          :Else
              req.Fail 500
              result‚Üê(error: 'Video generation failed')
          :EndIf
      :Else
          req.Fail 400
          result‚Üê(error: ‚éïDMX.Message)
      :EndTrap
    ‚àá

    ‚àá result‚ÜêServeVideo req;id;path
      :Access Public
      id‚Üêreq.PathParams.id
      :If ‚à®/'..'‚ç∑id
          req.Fail 403
          result‚Üê(error: 'Forbidden')
          :Return
      :EndIf
      path‚Üêroot,'/output/',id,'/animation.mp4'
      :If ‚éïNEXISTS path
          'Content-Type' req.SetHeader 'video/mp4'
          req.Response.Payload‚Üê'' path
          result‚Üê‚ç¨
      :Else
          req.Fail 404
          result‚Üê(detail: 'Video not found')
      :EndIf
    ‚àá

    ‚àá result‚ÜêGenerateSVG req;body;START;END;T;LA;LO;FPS;HIRES;SKIP;OPTS;SVG;ID;FN
      :Access Public
      :Trap 0
          body‚Üêreq.Payload
          START‚Üêbody.start
          END‚Üêbody.end
          T‚Üêbody.time
          LA‚Üêbody.lat
          LO‚Üêbody.long
          FPS‚Üêbody.fps
          HIRES‚Üêbody.hires
          SKIP‚Üêbody.skip
          OPTS‚ÜêFPS HIRES SKIP
          SVG‚ÜêOPTS ns.ANIMATEDSVG START END T LA LO
          ID‚Üê(‚àä‚äÉ‚éïSHELL 'date +%Y%m%d%H%M%S')~‚éïUCS 10 13 32
          FN‚Üêroot,'/output/',ID,'.svg'
          (‚äÇSVG)‚éïNPUT FN 1
          result‚Üê(url: '/api/svg/',ID)
      :Else
          req.Fail 400
          result‚Üê(error: ‚éïDMX.Message)
      :EndTrap
    ‚àá

    ‚àá result‚ÜêServeSVG req;id;path
      :Access Public
      id‚Üêreq.PathParams.id
      :If ‚à®/'..'‚ç∑id
          req.Fail 403
          result‚Üê(error: 'Forbidden')
          :Return
      :EndIf
      path‚Üêroot,'/output/',id,'.svg'
      :If ‚éïNEXISTS path
          'Content-Type' req.SetHeader 'image/svg+xml; charset=utf-8'
          req.Response.Payload‚Üê'' path
          result‚Üê‚ç¨
      :Else
          req.Fail 404
          result‚Üê(detail: 'SVG not found')
      :EndIf
    ‚àá

:EndClass
